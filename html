<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Fiza 🎂</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
        body{background:#000;color:#fff;height:100vh;overflow:hidden;display:flex;justify-content:center;align-items:center;text-align:center;}
        
        .bg-video{position:fixed;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:-2;filter:brightness(0.5);}
        .overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle,rgba(0,0,0,0)0%,rgba(0,0,0,0.8)100%);z-index:-1;}
        
        .container{padding:20px;z-index:1;max-width:600px;}
        .title{font-size:2.8rem;font-weight:800;background:linear-gradient(45deg,#ff6b9d,#ffd93d,#ff6b9d);background-size:200% 200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:glow 3s ease-in-out infinite alternate;}
        .name{font-size:3.5rem;color:#ff5fa2;margin:15px 0;text-shadow:0 0 20px rgba(255,95,162,0.8);font-weight:800;}
        
        .stage{display:none;flex-direction:column;justify-content:center;align-items:center;}
        .stage.active{display:flex;}
        
        .card{background:linear-gradient(145deg,rgba(255,255,255,0.15),rgba(255,255,255,0.05));backdrop-filter:blur(20px);border-radius:25px;padding:30px;margin:20px auto;max-width:500px;border:1px solid rgba(255,255,255,0.2);box-shadow:0 20px 40px rgba(0,0,0,0.4);}
        .card.arabic{font-family:'Noto Naskh Arabic',serif;font-size:1.8rem;line-height:1.6;color:#fff8dc;text-shadow:1px 1px 2px rgba(0,0,0,0.5);}
        
        .btn{margin:25px auto;padding:18px 45px;border-radius:50px;border:none;background:linear-gradient(45deg,#ff4d8d,#ff9bd5,#ffd93d);color:#fff;font-size:1.2rem;font-weight:700;cursor:pointer;transition:all 0.4s;box-shadow:0 8px 25px rgba(255,77,141,0.4);position:relative;overflow:hidden;}
        .btn:hover{transform:translateY(-3px) scale(1.05);box-shadow:0 15px 35px rgba(255,77,141,0.6);}
        .btn:active{transform:translateY(-1px);}
        
        .progress{display:flex;gap:10px;margin:20px 0;justify-content:center;}
        .progress-dot{width:12px;height:12px;border-radius:50%;background:#ff6b9d;transition:all 0.3s;}
        .progress-dot.active{transform:scale(1.5);background:#ffd93d;box-shadow:0 0 15px #ffd93d;}
        
        @keyframes glow{0%{filter:drop-shadow(0 0 10px #ff6b9d);}100%{filter:drop-shadow(0 0 30px #ffd93d);}}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
        .fade-in{animation:fadeInUp 0.8s ease-out;}
        
        .confetti{position:fixed;width:12px;height:12px;top:-12px;z-index:10;animation:fall 4s linear forwards;}
        @keyframes fall{to{transform:translateY(120vh) rotate(720deg);}}
    </style>
</head>
<body>
    <video class="bg-video" autoplay muted loop playsinline>
        <source src="https://cdn.coverr.co/videos/coverr-balloons-flying-9719/1080p.mp4" type="video/mp4">
    </video>
    <div class="overlay"></div>

    <audio id="music" loop preload="auto">
        <source src="https://www.soundjay.com/misc/sounds/bell-ringing-05.wav" type="audio/wav">
    </audio>

    <div class="container">
        <!-- Stage 1: Welcome -->
        <div id="stage1" class="stage active">
            <div class="title">🎉 Happy Birthday 🎉</div>
            <div class="name">Fiza Ahmad 💖</div>
            <div class="card fade-in">
                <div style="font-size:1.3rem;">Alhamdulillah! Another beautiful year of Allah's blessings ✨</div>
            </div>
            <button class="btn fade-in" onclick="nextStage(2)">🌟 Begin Special Prayers 🌟</button>
        </div>

        <!-- Stage 2-5: Prayers -->
        <div id="stage2" class="stage">
            <div class="progress">
                <div class="progress-dot active"></div><div class="progress-dot"></div><div class="progress-dot"></div><div class="progress-dot"></div>
            </div>
            <div class="card arabic fade-in">اللَّهُمَّ بَارِكْ لَهَا فِي عُمْرِهَا وَارْزُقْهَا الصِّحَّةَ وَالْعَافِيَةَ</div>
            <div class="card fade-in" style="font-size:1.1rem;color:#ffd93d;">Allahumma barik laha fi umriha warzuqha as-sihhata wal afiyah<br><small>*O Allah! Bless her in her lifetime and grant her health & well-being*</small></div>
            <button class="btn fade-in" onclick="nextStage(3)">الصَّلَاةُ الْأُولَى ➜</button>
        </div>

        <div id="stage3" class="stage">
            <div class="progress">
                <div class="progress-dot"></div><div class="progress-dot active"></div><div class="progress-dot"></div><div class="progress-dot"></div>
            </div>
            <div class="card arabic fade-in">رَبَّنَا هَبْ لَنَا مِنْ أَزْوَاجِنَا وَذُرِّيَّاتِنَا قُرَّةَ أَعْيُنٍ</div>
            <div class="card fade-in" style="font-size:1.1rem;color:#ffd93d;">Rabbana hablana min azwajina wa dhurriyyatina qurrata a’yunin<br><small>*Our Lord! Grant us from our spouses & offspring comfort to our eyes*</small></div>
            <button class="btn fade-in" onclick="nextStage(4)">الصَّلَاةُ الثَّانِيَة ➜</button>
        </div>

        <div id="stage4" class="stage">
            <div class="progress">
                <div class="progress-dot"></div><div class="progress-dot"></div><div class="progress-dot active"></div><div class="progress-dot"></div>
            </div>
            <div class="card arabic fade-in">وَاجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا</div>
            <div class="card fade-in" style="font-size:1.1rem;color:#ffd93d;">Waj'alna lil-muttaqina imama<br><small>*And make us leaders for the righteous*</small></div>
            <button class="btn fade-in" onclick="nextStage(5)">الصَّلَاةُ الثَّالِثَة ➜</button>
        </div>

        <div id="stage5" class="stage">
            <div class="progress">
                <div class="progress-dot"></div><div class="progress-dot"></div><div class="progress-dot"></div><div class="progress-dot active"></div>
            </div>
            <div class="card arabic fade-in">رَبَّنَا اغْفِرْ لَنَا وَلِإِخْوَانِنَا الَّذِينَ سَبَقُونَا بِالْإِيمَانِ</div>
            <div class="card fade-in" style="font-size:1.1rem;color:#ffd93d;">Rabbanagh fir lana wa li-ikhwanina alladhina sabaquna bil-iman<br><small>*Our Lord! Forgive us & those who preceded us in faith*</small></div>
            <button class="btn fade-in" onclick="showFinalMessage()">الصَّلَاةُ الرَّابِعَة ➜ الرِّسَالَةُ الْخَاصَّة</button>
        </div>

        <!-- Stage 6: Final Message -->
        <div id="stage6" class="stage">
            <div class="title" style="font-size:2rem;">💌 Special Message for Fiza 💌</div>
            <div class="card" style="max-width:550px;padding:35px;font-size:1.15rem;line-height:1.7;">
                <div style="color:#ffd93d;font-weight:700;font-size:1.3rem;margin-bottom:15px;">Dear Fiza,</div>
                <div>Ya Allah ki sab se khoobsurat niyamaton mein se ek niyamat ho tum! 🎁</div>
                <div>Jis din tum is duniya mein aayi, us din se har pal khubsurat ho gaya. Tumhari muskurahat mein jannat ki roshni hai, tumhare dil mein samundar ki gehraai hai.</div>
                <div><strong>Tumhari 4 khuwahishen:</strong></div>
                <div style="margin:15px 0;color:#ff9bd5;font-weight:600;">✨ Har dua qubool ho • Har khwab haqeeqat ban jaye</div>
                <div style="color:#ff9bd5;font-weight:600;">✨ Sehat hamesha saath rahe • Khushiyan kabhi na chhutein</div>
                <div style="margin:20px 0;font-style:italic;color:#fff;font-size:1rem;">"Tum jaisi ladkiyan Allah ke karam hoti hain... dil se dua hai ke tum hamesha khush raho!"</div>
                <div style="margin-top:25px;color:#ffd93d;font-weight:700;">Happy Birthday, meri jaan! 🥰🎂</div>
            </div>
            <button class="btn" onclick="startCelebration()">🎊 Celebrate Together! 🎊</button>
        </div>
    </div>

    <script>
        let currentStage = 1;
        
        function nextStage(stageNum) {
            document.getElementById(`stage${currentStage}`).classList.remove('active');
            currentStage = stageNum;
            document.getElementById(`stage${currentStage}`).classList.add('active');
            updateProgress();
        }
        
        function updateProgress() {
            document.querySelectorAll('.progress-dot').forEach((dot, index) => {
                dot.classList.toggle('active', index === currentStage - 2);
            });
        }
        
        function showFinalMessage() {
            nextStage(6);
        }
        
        function startCelebration() {
            document.getElementById('music').play().catch(e => console.log('Audio play failed'));
            
            // Epic Confetti
            for(let i=0; i<150; i++) {
                setTimeout(() => {
                    let c = document.createElement('div');
                    c.className = 'confetti';
                    c.style.left = Math.random() * 100 + 'vw';
                    c.style.background = `hsl(${Math.random() * 360}, 100%, ${50 + Math.random() * 30}%)`;
                    c.style.width = c.style.height = (8 + Math.random() * 8) + 'px';
                    c.style.animationDuration = (3 + Math.random() * 3) + 's';
                    document.body.appendChild(c);
                    setTimeout(() => c.remove(), 7000);
                }, i * 30);
            }
        }
    </script>
</body>
</html>
